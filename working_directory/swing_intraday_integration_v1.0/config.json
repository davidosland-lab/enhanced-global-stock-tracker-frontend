{
  "swing_trading": {
    "holding_period_days": 5,
    "stop_loss_percent": 3.0,
    "confidence_threshold": 52.0,
    "max_position_size": 0.25,
    "use_trailing_stop": true,
    "use_profit_targets": true,
    "use_regime_detection": true,
    "use_multi_timeframe": true,
    "use_volatility_sizing": true,
    "quick_profit_target_pct": 12.0,
    "profit_target_pct": 8.0,
    "min_holding_days_for_profit_target": 2
  },
  "intraday_monitoring": {
    "scan_interval_minutes": 15,
    "breakout_threshold": 70.0,
    "auto_trade_intraday": false,
    "max_intraday_positions": 0,
    "price_change_threshold": 2.0,
    "volume_multiplier": 1.5,
    "momentum_threshold": 3.0,
    "min_signal_strength": 60.0
  },
  "risk_management": {
    "max_total_positions": 3,
    "max_portfolio_heat": 0.06,
    "max_single_trade_risk": 0.02,
    "use_position_scaling": true,
    "min_position_size": 0.1,
    "max_volatility_multiplier": 2.0
  },
  "cross_timeframe": {
    "use_intraday_for_entries": true,
    "use_intraday_for_exits": true,
    "sentiment_boost_threshold": 70,
    "sentiment_block_threshold": 30,
    "early_exit_threshold": 80,
    "position_size_boost_pct": 0.05,
    "max_boosted_position_size": 0.30
  },
  "alerts": {
    "alert_threshold": 70.0,
    "max_alerts_per_hour": 20,
    "deduplicate_window_minutes": 30,
    "email": {
      "enabled": false,
      "from_address": "alerts@finbert-screener.com",
      "to_addresses": ["your.email@example.com"],
      "smtp_server": "smtp.gmail.com",
      "smtp_port": 587,
      "smtp_username": "your.username@gmail.com",
      "smtp_password": "your_app_password",
      "use_tls": true
    },
    "sms": {
      "enabled": false,
      "provider": "twilio",
      "twilio_account_sid": "YOUR_TWILIO_ACCOUNT_SID",
      "twilio_auth_token": "YOUR_TWILIO_AUTH_TOKEN",
      "twilio_from_number": "+1234567890",
      "to_numbers": ["+1234567890"]
    },
    "webhook": {
      "enabled": false,
      "type": "slack",
      "url": "https://hooks.slack.com/services/YOUR/WEBHOOK/URL",
      "custom_headers": {},
      "timeout_seconds": 10
    },
    "telegram": {
      "enabled": false,
      "bot_token": "",
      "chat_id": "",
      "parse_mode": "Markdown",
      "disable_notification": false
    }
  },
  "data_sources": {
    "use_yahoo_finance": true,
    "use_alpha_vantage": false,
    "alpha_vantage_api_key": "YOUR_API_KEY_HERE",
    "cache_duration_seconds": 300
  },
  "logging": {
    "level": "INFO",
    "log_to_file": true,
    "log_file": "logs/live_trading.log",
    "max_log_size_mb": 10,
    "backup_count": 5
  }
}
