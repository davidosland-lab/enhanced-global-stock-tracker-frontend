# Enhanced Stock Tracker - Environment Configuration Template
# ===========================================================
# Copy this file to `.env` and customize for your needs
#
# Note: Command-line arguments (--symbols) always override environment variables


# DEFAULT_SYMBOLS: Symbols used by production trading systems
# --------------------------------------------------------------
# Used by: enhanced_unified_platform.py, paper_trading_coordinator.py
# Default if not set: AAPL,GOOGL,MSFT,NVDA
#
# US Stocks Example:
# DEFAULT_SYMBOLS=AAPL,GOOGL,MSFT,NVDA,TSLA,AMZN,META
#
# Australian Stocks (ASX) Example:
DEFAULT_SYMBOLS=CBA.AX,BHP.AX,RIO.AX,NAB.AX,ANZ.AX,WBC.AX
#
# Mixed Markets Example:
# DEFAULT_SYMBOLS=AAPL,GOOGL,CBA.AX,BHP.AX


# TEST_SYMBOLS: Symbols used by integration tests
# ------------------------------------------------
# Used by: test_integration.py
# Default if not set: AAPL,GOOGL,MSFT,NVDA,TSLA
#
TEST_SYMBOLS=CBA.AX,BHP.AX,RIO.AX,NAB.AX,ANZ.AX


# BACKTEST_SYMBOLS: Symbols used for backtesting validation
# ----------------------------------------------------------
# Used by: test_backtest.py
# Default if not set: AAPL,GOOGL,MSFT,NVDA,AMD
#
BACKTEST_SYMBOLS=CBA.AX,BHP.AX,RIO.AX,NAB.AX,WBC.AX


# DEMO_SYMBOLS: Symbols used in demo/example code
# ------------------------------------------------
# Used by: ml_pipeline/prediction_engine.py (run_prediction_demo)
# Default if not set: AAPL,GOOGL,MSFT
#
DEMO_SYMBOLS=CBA.AX,BHP.AX,NAB.AX


# Additional Configuration (for future use)
# ------------------------------------------
# API_KEY=your_api_key_here
# LOG_LEVEL=INFO
# DATA_DIR=./data
# MODEL_DIR=./models
