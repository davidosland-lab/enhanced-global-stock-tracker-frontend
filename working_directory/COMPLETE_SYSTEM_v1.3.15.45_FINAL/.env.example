# ═══════════════════════════════════════════════════════════════════
#  Phase 3 Market Regime Intelligence System - Environment Config
#  Version: v1.3.13 - Complete Backend Package
#  
#  INSTRUCTIONS:
#  1. Copy this file to .env: cp .env.example .env
#  2. Update values below with your settings
#  3. NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────
#  FLASK APPLICATION SETTINGS
# ──────────────────────────────────────────────────────────────────

# Flask secret key (CHANGE THIS!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
FLASK_SECRET_KEY=your-secure-secret-key-change-this-in-production

# Flask environment (development or production)
FLASK_ENV=development

# Flask debug mode (True for development, False for production)
FLASK_DEBUG=True

# ──────────────────────────────────────────────────────────────────
#  AUTHENTICATION SETTINGS
# ──────────────────────────────────────────────────────────────────

# Admin credentials (CHANGE THESE!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Session timeout (in seconds)
SESSION_TIMEOUT=86400  # 24 hours

# ──────────────────────────────────────────────────────────────────
#  DASHBOARD SETTINGS
# ──────────────────────────────────────────────────────────────────

# Dashboard host (0.0.0.0 for all interfaces, 127.0.0.1 for local only)
DASHBOARD_HOST=0.0.0.0

# Dashboard port
DASHBOARD_PORT=5002

# ──────────────────────────────────────────────────────────────────
#  REGIME INTELLIGENCE SETTINGS
# ──────────────────────────────────────────────────────────────────

# Regime weight (0.0 to 1.0, recommended: 0.20)
REGIME_WEIGHT=0.20

# Confidence threshold (0.0 to 1.0, recommended: 0.30)
CONFIDENCE_THRESHOLD=0.30

# Enable adaptive weights (True/False)
ADAPTIVE_WEIGHTS=True

# ──────────────────────────────────────────────────────────────────
#  TRADING SETTINGS
# ──────────────────────────────────────────────────────────────────

# Initial capital (USD)
INITIAL_CAPITAL=100000

# Risk per trade (0.01 = 1%, 0.02 = 2%)
RISK_PER_TRADE=0.02

# Maximum positions
MAX_POSITIONS=10

# Stop loss percentage (0.05 = 5%)
STOP_LOSS_PCT=0.05

# Take profit percentage (0.15 = 15%)
TAKE_PROFIT_PCT=0.15

# Position sizing method (dynamic or fixed)
POSITION_SIZING=dynamic

# ──────────────────────────────────────────────────────────────────
#  TRANSACTION COST SETTINGS
# ──────────────────────────────────────────────────────────────────

# Commission rate (0.001 = 0.1%)
COMMISSION_RATE=0.001

# Spread rate (0.0005 = 0.05%)
SPREAD_RATE=0.0005

# Slippage rate (0.0002 = 0.02%)
SLIPPAGE_RATE=0.0002

# ──────────────────────────────────────────────────────────────────
#  DATA SOURCES & API SETTINGS
# ──────────────────────────────────────────────────────────────────

# Yahoo Finance timeout (seconds)
YFINANCE_TIMEOUT=10

# Cache timeout (seconds)
CACHE_TIMEOUT=3600  # 1 hour

# Enable data caching (True/False)
ENABLE_CACHING=True

# ──────────────────────────────────────────────────────────────────
#  LOGGING SETTINGS
# ──────────────────────────────────────────────────────────────────

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path (relative to project root)
LOG_FILE=data/logs/regime_intelligence.log

# Max log file size (bytes)
LOG_MAX_SIZE=10485760  # 10 MB

# Number of backup log files
LOG_BACKUP_COUNT=5

# Log format
LOG_FORMAT=[%(asctime)s] %(levelname)s - %(message)s

# ──────────────────────────────────────────────────────────────────
#  DATABASE SETTINGS (Optional - if using database)
# ──────────────────────────────────────────────────────────────────

# Database URL (uncomment and configure if using database)
# DATABASE_URL=postgresql://user:password@localhost:5432/regime_intelligence
# DATABASE_URL=sqlite:///data/regime_intelligence.db
# DATABASE_URL=mongodb://localhost:27017/regime_intelligence

# ──────────────────────────────────────────────────────────────────
#  EXTERNAL API KEYS (Optional)
# ──────────────────────────────────────────────────────────────────

# Alpha Vantage API key (if using)
# ALPHA_VANTAGE_API_KEY=your-api-key-here

# Polygon.io API key (if using)
# POLYGON_API_KEY=your-api-key-here

# IEX Cloud API key (if using)
# IEX_API_KEY=your-api-key-here

# ──────────────────────────────────────────────────────────────────
#  MONITORING & ALERTING (Optional)
# ──────────────────────────────────────────────────────────────────

# Sentry DSN for error tracking (if using)
# SENTRY_DSN=https://your-sentry-dsn-here

# Slack webhook URL for notifications (if using)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your-webhook-url

# Email settings for alerts (if using)
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=your-email@gmail.com
# EMAIL_SMTP_PASSWORD=your-app-password
# EMAIL_ALERT_TO=alerts@example.com

# ──────────────────────────────────────────────────────────────────
#  MARKET-SPECIFIC SETTINGS
# ──────────────────────────────────────────────────────────────────

# AU Market (ASX)
AU_MARKET_OPEN_TIME=09:00
AU_MARKET_CLOSE_TIME=16:00
AU_TIMEZONE=Australia/Sydney

# US Market (NASDAQ/NYSE)
US_MARKET_OPEN_TIME=09:30
US_MARKET_CLOSE_TIME=16:00
US_TIMEZONE=America/New_York

# UK Market (LSE)
UK_MARKET_OPEN_TIME=08:00
UK_MARKET_CLOSE_TIME=16:30
UK_TIMEZONE=Europe/London

# ──────────────────────────────────────────────────────────────────
#  ADVANCED SETTINGS (For experienced users)
# ──────────────────────────────────────────────────────────────────

# Backtesting start date (YYYY-MM-DD)
BACKTEST_START_DATE=2024-01-01

# Backtesting end date (YYYY-MM-DD)
BACKTEST_END_DATE=2025-12-31

# Cross-validation folds
CV_FOLDS=3

# Grid search regime weight values (comma-separated)
GRID_SEARCH_WEIGHTS=0.0,0.1,0.2,0.3,0.4

# Enable parallel processing (True/False)
ENABLE_PARALLEL=False

# Number of parallel workers (0 = auto-detect)
NUM_WORKERS=0

# ──────────────────────────────────────────────────────────────────
#  SECURITY SETTINGS (Production)
# ──────────────────────────────────────────────────────────────────

# Enable HTTPS redirect (True/False)
FORCE_HTTPS=False

# SSL certificate path (if using custom SSL)
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# Enable CORS (True/False)
ENABLE_CORS=False

# Allowed origins (comma-separated, if CORS enabled)
# ALLOWED_ORIGINS=https://example.com,https://app.example.com

# Rate limiting (requests per minute)
RATE_LIMIT=100

# ═══════════════════════════════════════════════════════════════════
#  IMPORTANT NOTES:
#  
#  1. CHANGE ALL DEFAULT PASSWORDS BEFORE PRODUCTION DEPLOYMENT
#  2. Generate secure secret keys using:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
#  3. Never commit the .env file to version control
#  4. Add .env to your .gitignore file
#  5. Use environment-specific .env files (.env.development, .env.production)
#  6. For Docker: use .env file or pass as environment variables
#  7. For production: consider using a secrets manager (AWS Secrets Manager, etc.)
# ═══════════════════════════════════════════════════════════════════
