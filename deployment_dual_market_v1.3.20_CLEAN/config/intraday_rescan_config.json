{
  "intraday_rescan": {
    "enabled": true,
    "scan_interval_minutes": 15,
    "markets": ["US", "ASX"],
    "auto_start_on_market_open": true,
    "auto_stop_on_market_close": true
  },
  
  "incremental_scanning": {
    "price_change_threshold": 2.0,
    "volume_multiplier": 1.5,
    "min_rescan_interval": 15
  },
  
  "breakout_detection": {
    "price_breakout_threshold": 2.0,
    "volume_spike_multiplier": 2.0,
    "momentum_threshold": 3.0,
    "min_signal_strength": 60.0
  },
  
  "alerts": {
    "alert_threshold": 70.0,
    "max_alerts_per_hour": 20,
    "deduplicate_window_minutes": 30,
    
    "email": {
      "enabled": false,
      "from_address": "alerts@finbert-screener.com",
      "to_addresses": [
        "your.email@example.com"
      ],
      "smtp_server": "smtp.gmail.com",
      "smtp_port": 587,
      "smtp_username": "your.username@gmail.com",
      "smtp_password": "your_app_password",
      "use_tls": true
    },
    
    "sms": {
      "enabled": false,
      "provider": "twilio",
      "twilio_account_sid": "YOUR_TWILIO_ACCOUNT_SID",
      "twilio_auth_token": "YOUR_TWILIO_AUTH_TOKEN",
      "twilio_from_number": "+1234567890",
      "to_numbers": [
        "+1234567890"
      ]
    },
    
    "webhook": {
      "enabled": false,
      "type": "slack",
      "url": "https://hooks.slack.com/services/YOUR/WEBHOOK/URL",
      "custom_headers": {},
      "timeout_seconds": 10
    },
    
    "telegram": {
      "enabled": true,
      "bot_token": "",
      "chat_id": "",
      "parse_mode": "Markdown",
      "disable_notification": false
    }
  },
  
  "tracking": {
    "max_tracked_opportunities": 100,
    "opportunity_expiry_hours": 4,
    "state_save_interval_minutes": 5
  },
  
  "performance": {
    "max_concurrent_api_calls": 5,
    "api_rate_limit_per_minute": 60,
    "cache_enabled": true,
    "cache_duration_seconds": 30
  },
  
  "logging": {
    "level": "INFO",
    "log_to_file": true,
    "log_file": "logs/intraday_rescan.log",
    "max_log_size_mb": 10,
    "backup_count": 5
  },
  
  "us_market": {
    "market_open_time": "09:30",
    "market_close_time": "16:00",
    "timezone": "America/New_York",
    "pre_market_scan": false,
    "after_hours_scan": false
  },
  
  "asx_market": {
    "market_open_time": "10:00",
    "market_close_time": "16:00",
    "timezone": "Australia/Sydney",
    "pre_market_scan": false,
    "after_hours_scan": false
  }
}
